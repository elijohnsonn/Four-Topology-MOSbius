C {code_shown.sym} 1220 -210 0 0 {name=Simulation only_toplevel=false 

value=

"
.control
op
let gmid_xm17 = @m.xm17.m0[gm]/@m.xm17.m0[id]
let gmid_xm16 = @m.xm16.m0[gm]/@m.xm16.m0[id]
let gmid_xm15 = @m.xm15.m0[gm]/@m.xm15.m0[id]
let gmid_xm11 = @m.xm11.m0[gm]/@m.xm11.m0[id]
let gmid_xm12 = @m.xm12.m0[gm]/@m.xm12.m0[id]
let gmid_xm10 = @m.xm10.m0[gm]/@m.xm10.m0[id]
let gmid_xm9  = @m.xm9.m0[gm]/@m.xm9.m0[id]
let gmid_xm8  = @m.xm8.m0[gm]/@m.xm8.m0[id]
let gmid_xm7  = @m.xm7.m0[gm]/@m.xm7.m0[id]
let gmid_xm6  = @m.xm6.m0[gm]/@m.xm6.m0[id]
let gmid_xm18 = @m.xm18.m0[gm]/@m.xm18.m0[id]
let gmid_xm14 = @m.xm14.m0[gm]/@m.xm14.m0[id]
let gmid_xm13 = @m.xm13.m0[gm]/@m.xm13.m0[id]
let gmid_xm5  = @m.xm5.m0[gm]/@m.xm5.m0[id]
let gmid_xm4  = @m.xm4.m0[gm]/@m.xm4.m0[id]
let gmid_xm3  = @m.xm3.m0[gm]/@m.xm3.m0[id]
let gmid_xm2  = @m.xm2.m0[gm]/@m.xm2.m0[id]
print gmid_xm17 gmid_xm16 gmid_xm15 gmid_xm11 gmid_xm12
print gmid_xm10 gmid_xm9 gmid_xm8 gmid_xm7 gmid_xm6
print gmid_xm18 gmid_xm14 gmid_xm13 gmid_xm5 gmid_xm4
print gmid_xm3 gmid_xm2

.endc
"}
