"
.control
op
print v(vbp2)
print v(vbn2)
let sat_m1  = abs(@m.xm1.m0[vds]) - abs(@m.xm1.m0[vdsat])
let sat_m2  = abs(@m.xm2.m0[vds]) - abs(@m.xm2.m0[vdsat])
