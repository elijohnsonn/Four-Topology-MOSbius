C {code_shown.sym} 1220 -200 0 0 {name=Simulation only_toplevel=false 

value=

"
.control

op

let sat_xm11 = abs(@m.xm11.m0[vds]) - abs(@m.xm11.m0[vdsat])
let sat_xm10 = abs(@m.xm10.m0[vds]) - abs(@m.xm10.m0[vdsat])
let sat_xm12 = abs(@m.xm12.m0[vds]) - abs(@m.xm12.m0[vdsat])
let sat_xm5  = abs(@m.xm5.m0[vds]) - abs(@m.xm5.m0[vdsat])
let sat_xm2  = abs(@m.xm2.m0[vds]) - abs(@m.xm2.m0[vdsat])
let sat_xm4  = abs(@m.xm4.m0[vds]) - abs(@m.xm4.m0[vdsat])
let sat_xm3  = abs(@m.xm3.m0[vds]) - abs(@m.xm3.m0[vdsat])
let sat_xm6  = abs(@m.xm6.m0[vds]) - abs(@m.xm6.m0[vdsat])
let sat_xm7  = abs(@m.xm7.m0[vds]) - abs(@m.xm7.m0[vdsat])
let sat_xm8  = abs(@m.xm8.m0[vds]) - abs(@m.xm8.m0[vdsat])
let sat_xm9  = abs(@m.xm9.m0[vds]) - abs(@m.xm9.m0[vdsat])
let sat_xm19 = abs(@m.xm19.m0[vds]) - abs(@m.xm19.m0[vdsat])
let sat_xm20 = abs(@m.xm20.m0[vds]) - abs(@m.xm20.m0[vdsat])
let sat_xm21 = abs(@m.xm21.m0[vds]) - abs(@m.xm21.m0[vdsat])
let sat_xm22 = abs(@m.xm22.m0[vds]) - abs(@m.xm22.m0[vdsat])
let sat_xm23 = abs(@m.xm23.m0[vds]) - abs(@m.xm23.m0[vdsat])
print sat_xm11 sat_xm10 sat_xm12
print sat_xm5 sat_xm2 sat_xm4 sat_xm3
print sat_xm6 sat_xm7 sat_xm8 sat_xm9
print sat_xm19 sat_xm20 sat_xm21 sat_xm22 sat_xm23

.endc
"}
